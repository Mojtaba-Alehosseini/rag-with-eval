# Copy to .env and edit. Every value here is OPTIONAL — with no .env at all the
# project runs fully offline with deterministic providers (great for CI/tests).

# ---- Provider selection -----------------------------------------------------
# llm:   auto | offline | ollama | gemini   (auto -> gemini if key, elif ollama, else offline)
# embed: auto | hashing | sentence-transformers | ollama
RAG_LLM_PROVIDER=auto
RAG_EMBED_PROVIDER=auto

# ---- Retrieval upgrade flags (the A/B knobs the eval harness compares) -------
RAG_RERANKER=none          # none | cross-encoder
RAG_HYBRID=false           # true -> fuse BM25 (lexical) + dense retrieval
RAG_TOP_K=5                # chunks retrieved before reranking
RAG_RERANK_TOP_N=5         # chunks kept after reranking
RAG_NO_ANSWER_THRESHOLD=0.18   # cosine floor to answer (semantic embedders)
RAG_NO_ANSWER_RECALL=0.40      # min query-term recall to answer (lexical/hashing embedder)

# ---- Chunking ---------------------------------------------------------------
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=200

# ---- Paths ------------------------------------------------------------------
RAG_CORPUS_DIR=data/corpus
RAG_PERSIST_DIR=.rag_index

# ---- Model names ------------------------------------------------------------
RAG_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ---- Ollama (local, free) ---------------------------------------------------
OLLAMA_HOST=http://localhost:11434
RAG_OLLAMA_LLM_MODEL=llama3.1:8b
RAG_OLLAMA_EMBED_MODEL=nomic-embed-text

# ---- Gemini (free tier — used for the hosted HF Spaces demo) -----------------
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
RAG_GEMINI_MODEL=gemini-1.5-flash

# NOTE: there is intentionally NO OPENAI_API_KEY. RAGAS defaults to an OpenAI
# judge; eval/run_eval.py reconfigures it to your local/Gemini judge so metrics
# compute with no OpenAI key. See eval/run_eval.py and section 0 of the spec.
